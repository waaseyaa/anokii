<!doctype html>
<html lang="{{ html_lang|default('en') }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Set your password &middot; Anokii</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    :root{
      --ink: var(--color-ink, #15171a);
      --bg: var(--color-side-bg, #0b0e13);
      --card: var(--color-card, #ffffff);
      --line: var(--color-line, #e3e1db);
      --muted: var(--color-muted, #6b7076);
      --accent: var(--color-primary, #0f766e);
      --accent-ink: var(--color-primary-ink, #ffffff);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:system-ui,sans-serif;font-size:15.5px;line-height:1.55;background:var(--bg);color:var(--ink);-webkit-font-smoothing:antialiased}
    a{color:inherit;text-decoration:none}
    .authpage{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:48px 20px}
    .authcard{width:100%;max-width:400px;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:30px 28px}
    .authcard .brand{display:flex;align-items:center;gap:10px;margin-bottom:18px}
    .authcard .brand .nm{letter-spacing:.02em;font-size:20px;font-weight:700;color:var(--ink)}
    .authcard h1{font-size:23px;margin:0 0 4px;color:var(--ink)}
    .authcard .sub{color:var(--muted);font-size:13.5px;margin:0 0 20px}
    .fld{margin-bottom:13px}
    .fld label{display:block;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
    .fld input{width:100%;border:1px solid var(--line);border-radius:9px;padding:11px 12px;font:inherit;font-size:14px;background:#fcfcfa;color:var(--ink)}
    .fld input:focus{outline:2px solid rgba(15,118,110,.18);border-color:var(--accent)}
    .abtn{width:100%;background:var(--accent);color:var(--accent-ink);border:none;border-radius:9px;padding:12px;font:inherit;font-weight:600;letter-spacing:.04em;font-size:13px;cursor:pointer}
    .abtn:hover{filter:brightness(.94)}
    .note{font-size:12px;color:var(--muted);margin-top:6px}
    .err{display:none;background:#fdecea;color:#a4291c;border-radius:9px;padding:9px 11px;font-size:13px;margin-bottom:14px}
    .err.show{display:block}
    .invalid{background:#fdecea;color:#a4291c;border-radius:9px;padding:14px 16px;font-size:14px}
  </style>
</head>
<body>
<div class="authpage"><div class="authcard">
  <div class="brand"><span class="nm">Anokii</span></div>
  {% if valid %}
    <h1>Set your password</h1>
    <p class="sub">Setting the password for <b>{{ email }}</b>. Choose something only you know.</p>
    <div class="err" id="err"></div>
    <form id="spForm">
      <div class="fld"><label for="pw">New password</label><input type="password" id="pw" required autocomplete="new-password" minlength="10"></div>
      <div class="fld"><label for="pw2">Confirm password</label><input type="password" id="pw2" required autocomplete="new-password" minlength="10"></div>
      <button class="abtn" type="submit">Set password and continue</button>
      <p class="note">At least 10 characters.</p>
    </form>
  {% else %}
    <h1>Link not valid</h1>
    <div class="invalid">This set-password link is invalid or has already been used. Ask for a fresh invite link.</div>
  {% endif %}
</div></div>

{% if valid %}
<script>
(function(){
  var f=document.getElementById('spForm'), err=document.getElementById('err');
  var token={{ token|json_encode|raw }};
  f.addEventListener('submit', function(e){
    e.preventDefault();
    err.classList.remove('show');
    var pw=document.getElementById('pw').value, pw2=document.getElementById('pw2').value;
    if(pw.length<10){ err.textContent='Password must be at least 10 characters.'; err.classList.add('show'); return; }
    if(pw!==pw2){ err.textContent='The two passwords do not match.'; err.classList.add('show'); return; }
    fetch('/admin/anokii/set-password', {
      method:'POST', headers:{'Content-Type':'application/json'}, credentials:'same-origin',
      body: JSON.stringify({token: token, password: pw})
    }).then(function(r){ return r.json().catch(function(){return {ok:false,error:'Something went wrong.'};}); })
      .then(function(d){
        if(d && d.ok){ window.location = d.redirect || '/admin/anokii/login'; }
        else { err.textContent=(d && d.error)||'Could not set password.'; err.classList.add('show'); }
      }).catch(function(){ err.textContent='Network error. Try again.'; err.classList.add('show'); });
  });
})();
</script>
{% endif %}
</body>
</html>
